{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "types": ["jest"],
    "paths": {
      "@bridge/*": ["./src/bridge/*"],
      "@core/*": ["./src/core/*"],
      "@features/*": ["./src/features/*"],
      "@ui/*": ["./src/ui/*"],
      "@store/*": ["./src/store/*"],
      "@utils/*": ["./src/utils/*"]
    }
  },
  "include": ["App.tsx", "nativewind-env.d.ts", "src/**/*", "*.ts", "*.tsx"]
}
