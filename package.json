{
  "name": "airhop",
  "version": "1.0.0",
  "description": "Private, offline-first messenger",
  "keywords": [
    "airhop",
    "messenger",
    "bluetooth",
    "p2p",
    "mesh-network",
    "offline-communication",
    "encrypted",
    "nostr"
  ],
  "author": "Areeb Ahmed <hi@areeb.dev>",
  "license": "MIT",
  "homepage": "https://airhop.free",
  "repository": {
    "type": "git",
    "url": "https://github.com/areebahmeddd/airhop"
  },
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "prebuild": "expo prebuild",
    "test": "jest --watchAll",
    "coverage": "jest --passWithNoTests --coverage",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "landing:dev": "npm --prefix landing run dev",
    "landing:build": "npm --prefix landing run build",
    "landing:start": "npm --prefix landing run start",
    "landing:format": "npm --prefix landing run format",
    "landing:format:check": "npm --prefix landing run format:check",
    "landing:lint": "npm --prefix landing run lint",
    "landing:typecheck": "npm --prefix landing run typecheck"
  },
  "dependencies": {
    "@cashu/cashu-ts": "^4.7.1",
    "@expo/vector-icons": "^15.1.1",
    "@noble/ciphers": "^2.2.0",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "expo": "~57.0.6",
    "expo-build-properties": "~57.0.5",
    "expo-status-bar": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "nativewind": "^4.2.6",
    "nostr-tools": "^2.23.12",
    "react": "^19.2.7",
    "react-native": "0.86.0",
    "react-native-encrypted-storage": "^4.0.3",
    "react-native-get-random-values": "^2.0.0",
    "react-native-mmkv": "^4.3.2",
    "react-native-nitro-modules": "^0.36.1",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "^4.5.2",
    "react-native-safe-area-context": "^5.8.0",
    "react-native-svg": "^15.15.4",
    "react-native-vision-camera": "^5.1.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.0",
    "@typescript-eslint/parser": "^8.64.0",
    "babel-preset-expo": "~57.0.3",
    "eslint": "^9.39.5",
    "eslint-config-expo": "~57.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~57.0.2",
    "prettier": "^3.9.5",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "tailwindcss": "^3.4.0",
    "typescript": "~6.0.3"
  },
  "jest": {
    "preset": "jest-expo",
    "testEnvironment": "node",
    "transformIgnorePatterns": [
      "node_modules/(?!(@noble|@scure|nostr-tools|@cashu|react-native|@react-native|expo|@expo|@unimodules|unimodules|nativewind|react-native-reanimated))"
    ],
    "moduleNameMapper": {
      "^@noble/curves/(.+?)(\\.js)?$": "<rootDir>/node_modules/@noble/curves/$1.js",
      "^@noble/hashes/(.+?)(\\.js)?$": "<rootDir>/node_modules/@noble/hashes/$1.js",
      "^@noble/ciphers/(.+?)(\\.js)?$": "<rootDir>/node_modules/@noble/ciphers/$1.js",
      "^react-native-encrypted-storage$": "<rootDir>/src/__mocks__/react-native-encrypted-storage.js"
    }
  }
}
